# Cloud Functions environment variables for LegacyBot.
# Copy this file to functions/.env and fill in your values.
# Never commit functions/.env — it is gitignored.
#
# Secrets are stored in Firebase Secret Manager (not in this file):
#   firebase functions:secrets:set SMTP_PASS
#   firebase functions:secrets:set GEMINI_API_KEY
#   firebase functions:secrets:set GOOGLE_MAPS_API_KEY
#
# ── Option A: Gmail (easiest for solo devs / testing) ──────────────────────
# Requires 2-Step Verification enabled on your Google account.
# Create an App Password at: Google Account → Security → App Passwords
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com

# ── Option B: Resend (recommended for shared / production use) ──────────────
# Sign up at resend.com, create an API key, verify your sending domain.
#
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend

# ── Option C: iCloud Mail ───────────────────────────────────────────────────
# Create an app-specific password at: appleid.apple.com → Sign-In & Security
#
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
# SMTP_USER=you@icloud.com

# ── Required for all options ────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
APP_URL=https://your-project.web.app
