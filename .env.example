# Firebase configuration — get these from the Firebase Console
# (Project Settings > General > Your apps > Config)
#
# These are public by design and ship in the client bundle. Security comes
# from Firestore + Storage Rules and from API key restrictions in the GCP
# Console (HTTP referrer + API allowlist) — NOT from keeping these "secret".
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ─────────────────────────────────────────────────────────────────────────
# DO NOT add VITE_GEMINI_API_KEY (or any other Gemini/Maps/secret key) to
# this file. Anything VITE_* prefixed is bundled into the browser JS and is
# trivially extractable. The Gemini API key lives ONLY in Firebase Secret
# Manager and is consumed server-side by the broker callables
# (mintGeminiLiveToken, invokeGemini, embedGemini).
#
# To set the server-side key:
#   firebase functions:secrets:set GEMINI_API_KEY
#
# See design.md §5 for the full API-key policy.
# ─────────────────────────────────────────────────────────────────────────
