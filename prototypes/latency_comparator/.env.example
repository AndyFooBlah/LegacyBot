# ============================================================================
# ⚠️  WARNING — LOCAL-DEV-ONLY PROTOTYPE. NEVER DEPLOY THIS APP. ⚠️
#
# Every VITE_* variable below is baked into the JavaScript bundle by Vite and
# is fully visible to anyone who opens the browser dev tools. That includes
# the Gemini API key. This is acceptable ONLY for a throwaway latency probe
# running on localhost. Do not host this prototype anywhere public, and use
# a disposable, quota-capped key you are willing to revoke.
#
# The production app (LegacyBot) deliberately does the opposite: keys stay in
# Firebase Secret Manager and the browser talks to server-side broker
# callables. See ../../DEPLOYMENT.md.
# ============================================================================

# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and must never be committed.

# --- Gemini (used by the frontend for LLM calls) ---
# Get your key at https://aistudio.google.com/apikey
# ⚠️ Visible in the browser bundle — local dev only (see banner above).
VITE_GEMINI_API_KEY=

# --- Gradium (used by both the proxy server and the frontend TTS call) ---
# Get your key at https://gradium.ai
VITE_GRADIUM_API_KEY=

# --- Gradium TTS voice ---
# List your available voices by calling GET https://us.api.gradium.ai/api/voices
# with your API key. Paste one of the returned voice IDs here.
# If left blank, the prototype will try "default" but this may not be valid.
VITE_GRADIUM_VOICE_ID=
